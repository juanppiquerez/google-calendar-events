# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# Full connection string used by Prisma and the API.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://booking:booking@localhost:5433/booking

# PostgreSQL credentials for the Docker Compose postgres service.
POSTGRES_DB=booking
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking

# =============================================================================
# API (NestJS)
# =============================================================================

# Port the API listens on (default: 3001).
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# =============================================================================
# Web (Next.js)
# =============================================================================

# Public base URL of the API, exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Host port mapped to the web container (container listens on 3000 internally).
WEB_PORT=3000

# =============================================================================
# Auth0 (Phase 1 — not used yet)
# =============================================================================

# Auth0 tenant domain, e.g. your-tenant.us.auth0.com
AUTH0_DOMAIN=

# Auth0 API audience identifier
AUTH0_AUDIENCE=

# Auth0 application client ID (SPA / regular web app)
AUTH0_CLIENT_ID=

# Auth0 application client secret (server-side only — never expose to the browser)
AUTH0_CLIENT_SECRET=

# Base URL of this application, used for Auth0 callback URLs
AUTH0_BASE_URL=http://localhost:3000

# =============================================================================
# Google Calendar (Phase 3 — not used yet)
# =============================================================================

# OAuth 2.0 client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# OAuth 2.0 client secret from Google Cloud Console (server-side only)
GOOGLE_CLIENT_SECRET=

# Redirect URI registered in Google Cloud Console for the OAuth flow
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# =============================================================================
# Security (Phase 3 — not used yet)
# =============================================================================

# 32-byte key (base64-encoded) used to encrypt stored Google refresh tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
