# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# Full connection string used by Prisma and the API.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://booking:booking@localhost:5433/booking

# PostgreSQL credentials for the Docker Compose postgres service.
POSTGRES_DB=booking
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking

# =============================================================================
# API (NestJS)
# =============================================================================

# Port the API listens on (default: 3001).
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# Public base URL of the frontend — used by the API for CORS and by Auth0 for callbacks.
APP_BASE_URL=http://localhost:3000

# =============================================================================
# Web (Next.js)
# =============================================================================

# Public base URL of the API, exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side API URL (used by Next.js server components). In Docker, set to http://api:3001.
API_URL=http://localhost:3001

# Host port mapped to the web container (container listens on 3000 internally).
WEB_PORT=3000

# =============================================================================
# Auth0
# =============================================================================

# Auth0 tenant domain, e.g. your-tenant.us.auth0.com
AUTH0_DOMAIN=

# Auth0 API audience identifier (create an API in the Auth0 Dashboard)
AUTH0_AUDIENCE=

# Auth0 application client ID (Regular Web Application)
AUTH0_CLIENT_ID=

# Auth0 application client secret (server-side only — never expose to the browser)
AUTH0_CLIENT_SECRET=

# Secret used by @auth0/nextjs-auth0 to encrypt session cookies.
# Generate with: openssl rand -hex 32
AUTH0_SECRET=

# =============================================================================
# Google Calendar
# =============================================================================

# OAuth 2.0 client ID from Google Cloud Console (Web application)
GOOGLE_CLIENT_ID=

# OAuth 2.0 client secret from Google Cloud Console (server-side only)
GOOGLE_CLIENT_SECRET=

# Must match an authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/google/callback

# =============================================================================
# Security
# =============================================================================

# 32-byte AES-256-GCM key as 64 hex characters — encrypts Google OAuth tokens at rest.
# Generate with: openssl rand -hex 32
# NEVER commit a real value to version control.
ENCRYPTION_KEY=

# =============================================================================
# Testing (CI / local only)
# =============================================================================

# Postgres URL for integration tests in CI (GitHub Actions sets this automatically).
# TEST_DATABASE_URL=postgresql://booking:booking@localhost:5432/booking_ci

# Set to "true" only when running Playwright E2E tests. Never enable in production.
# E2E_TEST_MODE=true
